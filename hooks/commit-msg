#!/bin/sh

MESSAGE=$(cat "$1")

# Ignorer les messages de merge automatique
if echo "$MESSAGE" | grep -q "^Merge"; then
    exit 0
fi

PATTERN="^(feat|fix|docs|test|style|chore|refactor|perf|ci|build|revert)(\([a-zA-Z0-9_-]+\))?: .{1,100}$"

if ! echo "$MESSAGE" | grep -qE "$PATTERN"; then
    echo ""
    echo "❌❌❌❌ [CAMERPAY] Erreur: Message de commit non conforme !"
    echo "Format attendu : <type>(<scope>): <description>"
    echo "Exemple : feat(auth): add login endpoint"
    echo "Types autorisés : feat, fix, docs, test, style, chore, refactor, perf, ci, build, revert"
    echo "*************************************************"
    exit 1
fi

echo "✅✅✅✅ [CAMERPAY] Message de commit conforme !"
exit 0